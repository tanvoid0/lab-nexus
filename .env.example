# Never run `pnpm db:seed` against production: the seed script exits when
# NODE_ENV=production or VERCEL_ENV=production (demo users and known passwords).
#
# Quick start: `docker compose --profile full up -d --build` — see README.md (Path A).

# MongoDB connection (local: docker run -p 27017:27017 mongo:7)
# With docker-compose.yml: after rs.initiate(), use replicaSet=rs0 (see docker-compose header).
DATABASE_URL="mongodb://127.0.0.1:27017/lab-nexus?replicaSet=rs0"

# Auth.js — generate: openssl rand -base64 32
AUTH_SECRET="replace-with-long-random-string"

# Optional: restrict sign-in emails to these domains (comma-separated). Same list applies to
# credential auth today; use for LDAP/IdP alignment. Subdomains allowed (e.g. cs.uni.edu for uni.edu).
# Leave unset to allow any domain (not recommended in production).
# LDAP_ALLOWED_DOMAINS="lab.local"

# Demo users for prisma seed + dev quick login (override defaults under lab.local).
# SEED_ADMIN_EMAIL="admin@lab.local"
# SEED_STAFF_EMAIL="researcher@lab.local"
# SEED_STUDENT_EMAIL="student@lab.local"
# Optional fixed demo password (e.g. for Playwright E2E with E2E_PASSWORD). If unset locally, seed writes a random password to prisma/.seed-demo-credentials.json (gitignored).
# SEED_DEMO_PASSWORD="choose-a-long-random-string"

# Optional: custom spreadsheet JSON for db:seed inventory upsert (otherwise synthetic placeholder rows).
# INVENTORY_SEED_JSON="C:/path/to/inventory-seed.json"
# INVENTORY_SEED_ITEM_COUNT="28"

# Optional: default functional (base) ISO 4217 currency when the lab has not saved Admin → Currencies yet
# (also used as the initial value on `pnpm db:seed`). Examples: USD, EUR, GBP, JPY.
# LAB_FUNCTIONAL_CURRENCY="USD"

# Optional: public URL for production (often needed for Docker Compose http://localhost:3000)
# AUTH_TRUST_HOST=true
# Used for absolute links in transactional email (overdue, etc.); any of:
# NEXTAUTH_URL="https://lab.example.edu"  # or AUTH_URL / APP_URL

# Cron: GET /api/cron/overdue — Authorization: Bearer <CRON_SECRET>
CRON_SECRET="replace-with-long-random-string"

# Optional email when checkouts become overdue (Resend — https://resend.com)
# RESEND_API_KEY="re_..."
# EMAIL_FROM="Lab Nexus <onboarding@resend.dev>"

# Optional Playwright authenticated tests (e2e/auth-flow.spec.ts)
# E2E_EMAIL="admin@lab.local"
# E2E_PASSWORD must match the seeded demo password (same as SEED_DEMO_PASSWORD or prisma/.seed-demo-credentials.json after seed).
# E2E_PASSWORD="your-seeded-demo-password"

# Optional: Lab assistant for signed-in users (Gemini — server only; see plan.md)
# GEMINI_API_KEY="your-key"
# Optional model id (default: gemini-2.0-flash)
# GEMINI_MODEL="gemini-flash-lite-latest"
# Optional timeout per request in ms (default 45000, max 120000)
# GEMINI_REQUEST_TIMEOUT_MS="45000"
# Set to "false" to disable assistant UI and POST /api/ai/chat even if GEMINI_API_KEY is set
# AI_ASSISTANT_ENABLED="false"
# Tight in-memory rate limits per Node process on POST /api/ai/chat (60s window). Defaults are very low (3 / user, 8 / IP).
# AI_CHAT_MAX_PER_USER_PER_MIN="3"
# AI_CHAT_MAX_PER_IP_PER_MIN="8"
